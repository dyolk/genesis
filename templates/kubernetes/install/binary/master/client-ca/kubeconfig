apiVersion: v1
kind: Config
clusters:
- name: default
  cluster:
    server: https://172.26.206.252:9443
    certificate-authority: /etc/kubernetes/pki/k8s-ca.crt
users:
  - name: admin
    user:
      client-certificate: /etc/kubernetes/pki/client.crt
      client-key: /etc/kubernetes/pki/client.key
contexts:
- context:
    cluster: default
    user: admin
  name: default
current-context: default
