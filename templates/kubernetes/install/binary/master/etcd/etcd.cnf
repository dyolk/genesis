ETCD_NAME=etcd1
ETCD_DATA_DIR=/data/etcd

ETCD_CERT_FILE=/etc/etcd/pki/etcd-server.crt
ETCD_KEY_FILE=/etc/etcd/pki/etcd-server.key
ETCD_TRUSTED_CA_FILE=/etc/kubernetes/pki/k8s-ca.crt
ETCD_CLIENT_CERT_AUTH=true
ETCD_LISTEN_CLIENT_URLS=https://172.26.206.250:2379
ETCD_ADVERTISE_CLIENT_URLS=https://172.26.206.250:2379

ETCD_PEER_CERT_FILE=/etc/etcd/pki/etcd-server.crt
ETCD_PEER_KEY_FILE=/etc/etcd/pki/etcd-server.key
ETCD_PEER_TRUSTED_CA_FILE=/etc/kubernetes/pki/k8s-ca.crt
ETCD_LISTEN_PEER_URLS=https://172.26.206.250:2380
ETCD_INITIAL_PEER_URLS=https://172.26.206.250:2380

ETCD_INITIAL_CLUSTER_TOKEN=$(( uuidgen ))
ETCD_INITIAL_CLUSTER="etcd1=https://172.26.206.250:2380,etcd2=https://172.26.206.251:2380,etcd3=https://172.26.206.253:2380"
ETCD_INITIAL_CLUSTER_STATE=new
